    results_table$P_value <- as.numeric(results_table$P_value)
    results_table <- results_table[!is.na(results_table$P_value) & results_table$P_value < 0.05, ]
    
    # let's only keep the 15 most significant GO terms
    results_table <- head(results_table, n = 20)
    
